---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('documents'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ['B&G', 'Victron', 'Efoy', 'E-Bar', 'Yanmar', 'Other'] as const;
const byCategory = Object.fromEntries(
  categories.map(cat => [cat, docs.filter(d => d.data.category === cat)])
);
---
<Base title="Documents">
  <h1 class="text-2xl font-bold mb-6">Documents</h1>
  {categories.filter(cat => byCategory[cat].length > 0).map(cat => (
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">{cat}</h2>
      <ul class="space-y-3">
        {byCategory[cat].map(doc => (
          <li class="border-b border-gray-100 pb-3">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-medium">{doc.data.title}</p>
                <p class="text-sm text-gray-500">{doc.data.description}</p>
                <p class="text-xs text-gray-400 mt-1">{doc.data.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}{doc.data.fileSize && ` · ${doc.data.fileSize}`}</p>
              </div>
              <div class="flex gap-3 shrink-0">
                <a href={doc.data.file} class="text-sm underline" target="_blank" rel="noopener">Open</a>
                <a href={doc.data.file} class="text-sm underline" download>Download</a>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>
  ))}
  {docs.length === 0 && <p class="text-gray-500">No documents yet.</p>}
</Base>
