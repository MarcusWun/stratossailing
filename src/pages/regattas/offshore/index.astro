---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const regattas = (await getCollection('regattas', ({ data }) => data.track === 'offshore' && data.status !== 'cancelled'))
  .sort((a, b) => a.data.startDate.valueOf() - b.data.startDate.valueOf());
---
<Base title="Offshore Schedule">
  <a href="/regattas/" class="text-sm text-gray-500 hover:underline mb-4 inline-block">← Regattas</a>
  <h1 class="text-2xl font-bold mb-6">Offshore Schedule</h1>
  {regattas.length === 0 && <p class="text-gray-500">No upcoming offshore events.</p>}
  <ul class="space-y-5">
    {regattas.map(r => (
      <li class="border-b border-gray-100 pb-5">
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-semibold">{r.data.name}</p>
            <p class="text-sm text-gray-500">
              {r.data.startDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
              {r.data.endDate && ` – ${r.data.endDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}`}
              {' · '}{r.data.location}
            </p>
            <p class="text-sm text-gray-500">{r.data.crewing}{r.data.class && ` · ${r.data.class}`}</p>
            {r.data.status === 'tentative' && <span class="text-xs text-amber-600">tentative</span>}
          </div>
          <div class="flex gap-3 text-sm shrink-0">
            {r.data.url && <a href={r.data.url} class="underline" target="_blank" rel="noopener">Info</a>}
            {r.data.norUrl && <a href={r.data.norUrl} class="underline" target="_blank" rel="noopener">NoR</a>}
            {r.data.siUrl && <a href={r.data.siUrl} class="underline" target="_blank" rel="noopener">SI</a>}
          </div>
        </div>
      </li>
    ))}
  </ul>
</Base>
