---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const track = Astro.url.searchParams.get('track');
const posts = track ? allPosts.filter(p => p.data.track === track) : allPosts;
---
<Base title="Blog">
  <h1 class="text-2xl font-bold mb-2">Race Reports</h1>
  <div class="flex gap-3 mb-6 text-sm">
    <a href="/blog/" class={!track ? 'font-semibold underline' : 'hover:underline'}>All</a>
    <a href="/blog/?track=offshore" class={track === 'offshore' ? 'font-semibold underline' : 'hover:underline'}>Offshore</a>
    <a href="/blog/?track=inshore" class={track === 'inshore' ? 'font-semibold underline' : 'hover:underline'}>Inshore</a>
  </div>
  {posts.length === 0 && <p class="text-gray-500">No posts yet.</p>}
  <ul class="space-y-5">
    {posts.map(post => (
      <li class="border-b border-gray-100 pb-5">
        <a href={`/blog/${post.id}/`} class="text-lg font-medium hover:underline">{post.data.title}</a>
        <p class="text-sm text-gray-500 mt-1">
          {post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          {' · '}{post.data.location} · {post.data.crewing}
          {post.data.result && <span class="ml-2 font-medium text-gray-700">{post.data.result}</span>}
        </p>
      </li>
    ))}
  </ul>
</Base>
